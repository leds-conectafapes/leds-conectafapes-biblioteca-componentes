{
  "name": "@leds-ifes/components",
  "description": "Biblioteca de componentes Vue para o projeto ConectaFapes",
  "author": "LedsConectaFapes",
  "license": "MIT",
  "readme": "./README.npm.md",
  "private": false,
  "version": "1.1.1",
  "main": "src/leds-ifes-types.ts",
  "files": [
    "src/components/*.vue",
    "src/leds-ifes-styles.css"
  ],
  "exports": {
